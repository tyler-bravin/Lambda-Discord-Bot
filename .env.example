# Copy this file to .env and fill in your values.
# (On Coolify you can set these as environment variables in the UI instead.)

# --- Required ---
# Your Discord bot token, from https://discord.com/developers/applications
DISCORD_TOKEN=

# --- Optional: Spotify link support ---
# From https://developer.spotify.com/dashboard/ — without these, Spotify links
# are disabled but everything else works.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=

# --- Optional: tuning (the defaults are fine for most setups) ---

# Directory for persistent data: music_queue.db, tasks.json, cookies.txt, yt-dlp cache.
# Defaults to the working directory; the Docker image sets this to /data.
#DATA_DIR=.

# Upgrade yt-dlp on container start and every 6 hours while running. Set 0 to pin
# the installed version.
#YTDLP_AUTO_UPDATE=1

# Explicit path to a Netscape-format YouTube cookies file.
# Defaults to $DATA_DIR/cookies.txt (used only if the file exists).
#YTDLP_COOKIES=

# Read YouTube cookies from a local browser profile, e.g. "chrome" or
# "firefox:ProfileName". Only works OUTSIDE Docker, on a machine with a
# logged-in browser — a headless container has no browser to read from.
#YTDLP_COOKIES_FROM_BROWSER=

# URL of the bgutil PO token provider. docker-compose.yml sets this automatically;
# only set it manually if you run the provider elsewhere.
#POT_PROVIDER_URL=http://bgutil-provider:4416

# Path of the healthcheck heartbeat file (rarely needs changing).
#HEARTBEAT_FILE=

# Sync slash commands to a single guild for instant availability while testing
# (global syncs can take up to an hour). Set to your server's ID.
#TEST_GUILD_ID=

# --- Optional: TaskBoard web dashboard ---
# Set to 1 to run the web dashboard inside the bot. Requires the OAuth2 values below.
#WEB_ENABLED=0
# OAuth2 credentials from your bot's application (Developer Portal > OAuth2).
# DISCORD_CLIENT_ID is your application ID; the secret is the OAuth2 client secret.
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=
# Must exactly match a redirect registered under OAuth2 > Redirects, e.g.
# https://tasks.example.com/callback  (or http://localhost:8080/callback for local use)
#WEB_REDIRECT_URI=
# Bind address/port for the dashboard.
#WEB_HOST=0.0.0.0
#WEB_PORT=8080
# Set to 1 when served over HTTPS so session cookies are marked Secure.
#WEB_SECURE=0
# Stable random string that signs session cookies (keeps logins valid across
# restarts). Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
#WEB_SECRET_KEY=
# Public base URL used to build the /np/<server> "now playing" links posted by
# the !player command. Defaults to WEB_REDIRECT_URI minus /callback.
#WEB_BASE_URL=https://tasks.example.com
# Set to 1 to show playback controls on the now-playing screen. Controlling
# requires Discord login AND being in the bot's voice channel (admins always).
# The now-playing *view* is public read-only regardless.
#WEB_CONTROLS=0
